    "SideDeck": {
      "additionalProperties": false,
      "description": "One side's Arts of War deck state.\n\n`deck` is the face-down draw pile (shuffled at start of each Levy\nvia 3.1.1). `discard` is the face-up pile that returns to deck on\nshuffle except for `removed` cards. `capabilities_in_play` are\nside-wide capabilities under the player's board edge (this-lord\ncapabilities live on the Lord's mat in `Lord.this_lord_capabilities`).\n`holds` are face-down Hold-event cards in the player's hand.\n`pending_draw` are cards drawn during the current Arts of War step\nthat have not yet been implemented (3.1.2 / 3.1.3).\n`this_levy_events` and `this_campaign_events` are persistence\nbuckets per 3.1.3.\n`plan` is the Command-card stack for the current Campaign (4.1).",
      "properties": {
        "deck": {
          "items": {
            "type": "string"
          },
          "title": "Deck",
          "type": "array"
        },
        "discard": {
          "items": {
            "type": "string"
          },
          "title": "Discard",
          "type": "array"
        },
        "removed": {
          "items": {
            "type": "string"
          },
          "title": "Removed",
          "type": "array"
        },
        "capabilities_in_play": {
          "items": {
            "type": "string"
          },
          "title": "Capabilities In Play",
          "type": "array"
        },
        "holds": {
          "items": {
            "type": "string"
          },
          "title": "Holds",
          "type": "array"
        },
        "pending_draw": {
          "items": {
            "type": "string"
          },
          "title": "Pending Draw",
          "type": "array"
        },
        "this_levy_events": {
          "items": {
            "type": "string"
          },
          "title": "This Levy Events",
          "type": "array"
        },
        "this_campaign_events": {
          "items": {
            "type": "string"
          },
          "title": "This Campaign Events",
          "type": "array"
        },
        "plan": {
          "items": {
            "type": "string"
          },
          "title": "Plan",
          "type": "array"
        }
      },
      "title": "SideDeck",
      "type": "object"
    },
    "VassalState": {
      "additionalProperties": false,
      "description": "Per-Vassal mutable state.\n\n`ready` reflects the Vassal Service marker face (CoA up = ready, CoA\ndown = unready). `mustered` is true once the Vassal's Forces have\nbeen deployed onto the Lord's mat via Muster Vassal action (3.4.2);\nwhen mustered, the Vassal's Forces are merged into the parent Lord's\n`forces` dict.\n\n`on_calendar` and `calendar_box` cover the Advanced Vassal Service\noptional rule (3.4.2) where a Vassal's Service marker is placed on\nthe Calendar instead of staying on the Lord's mat. For Phase 2 this\nis captured but not exercised by any default action; the basic\nMuster Vassal action keeps markers on the mat.",
      "properties": {
        "vassal_id": {
          "title": "Vassal Id",
          "type": "string"
        },
        "ready": {
          "default": true,
          "title": "Ready",
          "type": "boolean"
        },
        "mustered": {
          "default": false,
          "title": "Mustered",
          "type": "boolean"
        },
        "on_calendar": {
          "default": false,
          "title": "On Calendar",
          "type": "boolean"
        },
        "calendar_box": {
          "anyOf": [
            {
              "maximum": 16,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Calendar Box"
        }
      },
      "required": [
        "vassal_id"
      ],
      "title": "VassalState",
      "type": "object"
    },
