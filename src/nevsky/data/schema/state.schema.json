    "Locale": {
      "additionalProperties": false,
      "description": "Locale state. Static data (type, territory, seats, seaport, VP)\nis in data/static/locales.json and looked up by locale_id.\n\nConquered counts can stack: a fully Conquered City carries 2\nmarkers (matching its 2-VP value); fully Conquered Novgorod carries\n3. Markers are added per Conquest event and stay until removed.\n\n`walls_plus_one` (R18 Stone Kremlin) is restricted at validation\ntime to Russian Forts, Cities, and Novgorod (Phase 2 enforces; the\npydantic field is just a bool).",
      "properties": {
        "locale_id": {
          "title": "Locale Id",
          "type": "string"
        },
        "russian_conquered": {
          "default": 0,
          "minimum": 0,
          "title": "Russian Conquered",
          "type": "integer"
        },
        "teutonic_conquered": {
          "default": 0,
          "minimum": 0,
          "title": "Teutonic Conquered",
          "type": "integer"
        },
        "russian_ravaged": {
          "default": false,
          "title": "Russian Ravaged",
          "type": "boolean"
        },
        "teutonic_ravaged": {
          "default": false,
          "title": "Teutonic Ravaged",
          "type": "boolean"
        },
        "russian_castle": {
          "default": false,
          "title": "Russian Castle",
          "type": "boolean"
        },
        "teutonic_castle": {
          "default": false,
          "title": "Teutonic Castle",
          "type": "boolean"
        },
        "walls_plus_one": {
          "default": false,
          "title": "Walls Plus One",
          "type": "boolean"
        },
        "siege_markers": {
          "default": 0,
          "maximum": 4,
          "minimum": 0,
          "title": "Siege Markers",
          "type": "integer"
        }
      },
      "required": [
        "locale_id"
      ],
      "title": "Locale",
      "type": "object"
    },
    "Lord": {
      "additionalProperties": false,
      "description": "Lord state. Static data (ratings, seats, starting forces) is in\ndata/static/lords.json and looked up by lord_id; only mutable state\nlives here.\n\n`forces` is the Lord's CURRENT force composition: starting forces\nplus any Mustered Vassal forces, minus combat losses. Force counts\nare integers per type; rules treat half-counts as a marker side, but\nthe harness tracks integers and emits half Hits during combat\nresolution rather than storing fractional units (Phase 3).\n\n`assets` carries Coin / Provender / Loot plus Transport sub-types\n(Boat, Cart, Sled, Ship). Whether Ships are allowed for the Lord is\ndetermined by static data (`ships_authorized`); the loader rejects\nShip counts > 0 for Lords who lack the authorization.\n\n`lordship_used` and `just_arrived_this_levy` are Phase 2 fields used\nduring Muster (3.4) and reset at end of Levy.",
      "properties": {
        "lord_id": {
          "title": "Lord Id",
          "type": "string"
        },
        "side": {
          "enum": [
            "teutonic",
            "russian"
          ],
          "title": "Side",
          "type": "string"
        },
        "location": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Locale id where this Lord is on the map; None if not mustered.",
          "title": "Location"
        },
        "state": {
          "default": "ready",
          "enum": [
            "ready",
            "mustered",
            "disbanded",
            "removed"
          ],
          "title": "State",
          "type": "string"
        },
        "moved_fought": {
          "default": false,
          "title": "Moved Fought",
          "type": "boolean"
        },
        "forces": {
          "additionalProperties": {
            "type": "integer"
          },
          "propertyNames": {
            "enum": [
              "knights",
              "sergeants",
              "men_at_arms",
              "militia",
              "light_horse",
              "asiatic_horse",
              "serfs"
            ]
          },
          "title": "Forces",
          "type": "object"
        },
        "assets": {
          "additionalProperties": {
            "type": "integer"
          },
          "propertyNames": {
            "enum": [
              "coin",
              "provender",
              "loot",
              "boat",
              "cart",
              "sled",
              "ship"
            ]
          },
          "title": "Assets",
          "type": "object"
        },
        "vassals": {
          "additionalProperties": {
            "$ref": "#/$defs/VassalState"
          },
          "title": "Vassals",
          "type": "object"
        },
        "this_lord_capabilities": {
          "items": {
            "type": "string"
          },
          "title": "This Lord Capabilities",
          "type": "array"
        },
        "lordship_used": {
          "default": 0,
          "title": "Lordship Used",
          "type": "integer"
        },
        "just_arrived_this_levy": {
          "default": false,
          "title": "Just Arrived This Levy",
          "type": "boolean"
        }
      },
      "required": [
        "lord_id",
        "side"
      ],
      "title": "Lord",
      "type": "object"
    },
