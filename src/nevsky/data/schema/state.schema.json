        },
        "to_locale": {
          "title": "To Locale",
          "type": "string"
        },
        "way_type": {
          "title": "Way Type",
          "type": "string"
        },
        "defender_side": {
          "enum": [
            "teutonic",
            "russian"
          ],
          "title": "Defender Side",
          "type": "string"
        },
        "defender_lords": {
          "items": {
            "type": "string"
          },
          "title": "Defender Lords",
          "type": "array"
        },
        "pending_response_by": {
          "enum": [
            "teutonic",
            "russian"
          ],
          "title": "Pending Response By",
          "type": "string"
        },
        "laden": {
          "default": false,
          "title": "Laden",
          "type": "boolean"
        }
      },
      "required": [
        "attacker_side",
        "from_locale",
        "to_locale",
        "way_type",
        "defender_side",
        "pending_response_by"
      ],
      "title": "CombatPending",
      "type": "object"
    },
