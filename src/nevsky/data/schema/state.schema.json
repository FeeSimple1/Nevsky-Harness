    "CombatPending": {
      "additionalProperties": false,
      "description": "Pending Approach / Battle decision (4.3.4 - 4.4).\n\nSet by cmd_march when Marching into a Locale containing enemy\nLord(s). Defender (whose Lords are at the target) chooses one of:\navoid_battle (Unladen, 4.3.4), withdraw (4.3.4 into a Friendly\nStronghold), or stand_battle (4.4 begins).\nCleared after the chosen response resolves.",
      "properties": {
        "attacker_side": {
          "enum": [
            "teutonic",
            "russian"
          ],
          "title": "Attacker Side",
          "type": "string"
        },
        "attacker_group": {
